# Copy to .env and fill with rotated credentials.
# Do NOT commit .env — it is gitignored.

# Sanity CMS
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=

# Mux (backend/scripts — playback uses public muxPlaybackId from Sanity)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
